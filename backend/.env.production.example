# Database configuration
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# Cache / BullMQ configuration
REDIS_URL="rediss://default:password@host:port"

# HTTP Server configuration
PORT=5000
NODE_ENV=production

# JWT Authentication
JWT_SECRET="use-openssl-rand-hex-32-to-generate-a-strong-jwt-secret-key"
JWT_REFRESH_SECRET="use-openssl-rand-hex-32-to-generate-a-strong-jwt-refresh-secret-key"

# Security Encryption Key
ENCRYPTION_KEY="use-openssl-rand-hex-32-to-generate-a-strong-aes-256-encryption-key-must-be-64-hex-chars"

# Cloudflare R2 KYC Storage configuration (Phase 2)
R2_ACCESS_KEY_ID="cloudflare-r2-access-key-id"
R2_SECRET_ACCESS_KEY="cloudflare-r2-secret-access-key"
R2_BUCKET_NAME="innovpay-kyc"
R2_ENDPOINT="https://account_id.r2.cloudflarestorage.com"

# Resend Email Service configuration (Phase 3)
RESEND_API_KEY="re_your_resend_api_key"
MAIL_FROM="Innov Pay <noreply@innovpay.td>"
FRONTEND_URL="https://frontend-polo6.vercel.app"

# Payment Providers configuration (Phase 4)
PAYMENT_MODE="production"
AIRTEL_BASE_URL="https://openapi.airtel.in"
AIRTEL_CLIENT_ID="your_airtel_client_id"
AIRTEL_CLIENT_SECRET="your_airtel_client_secret"
AIRTEL_MERCHANT_ID="your_airtel_merchant_id"
MOOV_BASE_URL="https://api.moov-africa.td"
MOOV_API_KEY="your_moov_api_key"
MOOV_MERCHANT_CODE="your_moov_merchant_code"
ORANGE_BASE_URL="https://api.orange.com"
ORANGE_CLIENT_ID="your_orange_client_id"
ORANGE_CLIENT_SECRET="your_orange_client_secret"
ORANGE_MERCHANT_KEY="your_orange_merchant_key"
